# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/hmis_db

# Redis Connection URL
REDIS_URL=redis://localhost:6379/0

# JWT Security Secrets
JWT_SECRET=hmis_platform_jwt_secret_key_change_in_production_2026
JWT_REFRESH_SECRET=hmis_platform_jwt_refresh_secret_key_change_in_production_2026
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# Inventory Sync Bridge Connection
INVENTORY_API_BASE_URL=https://inventory.agpkacademy.in
INVENTORY_BRIDGE_API_KEY=test_bridge_api_key_123456

# Application Server Profile Settings
DEBUG=True
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8002
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173


# S3-Compatible File Storage
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_BUCKET_NAME=hmis-records
S3_REGION_NAME=us-east-1

# ABDM Gateway / ABHA Sandbox Configuration
ABDM_CLIENT_ID=your_abdm_client_id
ABDM_CLIENT_SECRET=your_abdm_client_secret
ABDM_GATEWAY_URL=https://dev.abdm.gov.in

# WhatsApp Messaging Gateway Credentials
WHATSAPP_API_URL=https://api.whatsapp.com/v1/messages
WHATSAPP_API_TOKEN=your_whatsapp_token_here

# Expo Push Notifications Access Key
EXPO_ACCESS_TOKEN=your_expo_access_token_here

# PayU Checkout Credentials
PAYU_MERCHANT_KEY=your_payu_merchant_key
PAYU_MERCHANT_SALT=your_payu_merchant_salt
PAYU_ENV=test
PAYU_SUCCESS_URL=http://localhost:3000/payment/success
PAYU_FAILURE_URL=http://localhost:3000/payment/failure

# Telemedicine Jitsi Host Domain
JITSI_DOMAIN=meet.jit.si

# Google Gemini API Key for clinical summaries
GEMINI_API_KEY=your_gemini_api_key_here

# DMS Bridge Integration Settings
DMS_API_BASE_URL=http://localhost:8000
DMS_BRIDGE_API_KEY=change-me-long-random-secret
DMS_WEBHOOK_SECRET=change-me-webhook-secret
DMS_INTEGRATION_ENABLED=true
DMS_REQUEST_TIMEOUT_SECONDS=15

